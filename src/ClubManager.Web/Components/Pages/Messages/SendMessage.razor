@page "/messages/send"
@attribute [Authorize(Roles = "Admin,ClubManager")]
@inject MessageService MsgSvc
@inject ClubService ClubSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nová zpráva</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Nová zpráva</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudSelect T="int?" Label="Organizace" Value="_orgId" Required="true"
                       ValueChanged="OnOrgSelect">
                <MudSelectItem Value="(int?)null">— vyberte organizaci —</MudSelectItem>
                @foreach (var o in _orgs)
                {
                    <MudSelectItem Value="(int?)o.Id">@o.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="int?" Label="Oddíl (volitelné)" Value="_clubId"
                       ValueChanged="OnClubSelect">
                <MudSelectItem Value="(int?)null">— celá organizace —</MudSelectItem>
                @foreach (var c in _clubs)
                {
                    <MudSelectItem Value="(int?)c.Id">@c.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="ClubManager.Models.MessageType" Label="Typ" @bind-Value="_type">
                <MudSelectItem Value="ClubManager.Models.MessageType.General">Obecné</MudSelectItem>
                <MudSelectItem Value="ClubManager.Models.MessageType.Reminder">Připomínka</MudSelectItem>
                <MudSelectItem Value="ClubManager.Models.MessageType.Debt">Nedoplatek</MudSelectItem>
                <MudSelectItem Value="ClubManager.Models.MessageType.Event">Událost</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField Label="Předmět" @bind-Value="_subject" Required="true" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField Label="Zpráva" @bind-Value="_body" Lines="6" Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudCheckBox @bind-Value="_sendEmail" Label="Odeslat emailem" />
            <MudCheckBox @bind-Value="_sendNtfy" Label="Odeslat přes ntfy" />
        </MudItem>

        @* ── Preview příjemců ──────────────────────────────── *@
        @if (_orgId.HasValue)
        {
            <MudItem xs="12">
                <MudPaper Class="pa-3 mud-background-gray rounded-lg" Elevation="0">
                    @if (_loadingRecipients)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            Načítám příjemce…
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" GutterBottom="true">
                            <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-1" />
                            Zpráva bude odeslána <strong>@_recipientPreview.Count</strong> @(_recipientPreview.Count == 1 ? "příjemci" : "příjemcům")
                            @if (_clubId.HasValue) { <span> (oddíl)</span> } else { <span> (celá organizace)</span> }
                        </MudText>
                        @if (_recipientPreview.Any())
                        {
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                @foreach (var name in _recipientPreview.Take(10))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@name</MudChip>
                                }
                                @if (_recipientPreview.Count > 10)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">+@(_recipientPreview.Count - 10) dalších</MudChip>
                                }
                            </MudStack>
                        }
                    }
                </MudPaper>
            </MudItem>
        }

        <MudItem xs="12">
            <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="SendAsync"
                       Disabled="@(_sending || _recipientPreview.Count == 0)" StartIcon="@Icons.Material.Filled.Send">
                @if (_sending) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Odeslat @(_recipientPreview.Count > 0 ? $"({_recipientPreview.Count})" : "")
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    int? _orgId, _clubId;
    string _subject = "", _body = "";
    bool _sendEmail = true, _sendNtfy = false, _sending, _loadingRecipients;
    ClubManager.Models.MessageType _type = ClubManager.Models.MessageType.General;
    List<ClubManager.Models.Organization> _orgs = [];
    List<ClubManager.Models.Club> _clubs = [];
    List<string> _recipientPreview = [];

    protected override async Task OnInitializedAsync()
    {
        _orgs = await ClubSvc.GetOrganizationsAsync();
    }

    async Task OnOrgSelect(int? id)
    {
        _orgId = id;
        _clubId = null;
        _clubs = id.HasValue ? await ClubSvc.GetClubsAsync(id.Value) : [];
        await RefreshRecipientsAsync();
    }

    async Task OnClubSelect(int? id)
    {
        _clubId = id;
        await RefreshRecipientsAsync();
    }

    async Task RefreshRecipientsAsync()
    {
        if (_orgId is null) { _recipientPreview = []; return; }
        _loadingRecipients = true;
        var members = await ClubSvc.GetMembersAsync(_orgId.Value, _clubId);
        _recipientPreview = members.Select(m => m.DisplayName ?? m.User?.UserName ?? m.UserId).Distinct().ToList();
        _loadingRecipients = false;
    }

    async Task SendAsync()
    {
        if (_orgId is null || string.IsNullOrWhiteSpace(_subject) || string.IsNullOrWhiteSpace(_body))
        {
            Snackbar.Add("Vyplňte organizaci, předmět a text zprávy.", MudBlazor.Severity.Warning);
            return;
        }
        _sending = true;
        try
        {
            var members = await ClubSvc.GetMembersAsync(_orgId.Value, _clubId);
            var userIds = members.Select(m => m.UserId).Distinct().ToList();

            var msg = await MsgSvc.CreateDraftAsync(new ClubManager.Models.Message
            {
                OrganizationId = _orgId.Value,
                ClubId = _clubId,
                SenderUserId = "system",
                Subject = _subject,
                Body = _body,
                Type = _type,
                SendEmail = _sendEmail,
                SendNtfy = _sendNtfy
            });

            await MsgSvc.SendMessageAsync(msg.Id, userIds);
            Snackbar.Add($"Zpráva odeslána {userIds.Count} příjemcům.", MudBlazor.Severity.Success);
            Nav.NavigateTo("/messages");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Chyba: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally { _sending = false; }
    }
}
